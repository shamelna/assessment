# ========================================
# Firebase Configuration (REQUIRED)
# ========================================
# Get these values from Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# ========================================
# Email Configuration (REQUIRED)
# ========================================
# Get API key from Resend Dashboard → API Keys
RESEND_API_KEY=re_your_api_key_here
# Email to receive admin notifications
ADMIN_EMAIL=ahmed.a.redwan@gmail.com

# ========================================
# ConvertKit Configuration (OPTIONAL)
# ========================================
# For marketing automation and lead nurturing
CONVERTKIT_API_SECRET=your_api_secret_here
CONVERTKIT_SEQUENCE_ID=your_sequence_id_here

# ========================================
# Development Options (OPTIONAL)
# ========================================
# Enable Firebase emulator for local development
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Force static export mode (for GitHub Pages)
# NEXT_PUBLIC_STATIC_EXPORT=true
